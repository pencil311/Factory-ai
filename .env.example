# FactoryPilot AI — backend environment template
#
# Copy to .env and fill in real values. NEVER commit .env: it is gitignored
# because it holds live database credentials.
#
#   cp .env.example .env

# --- Database ---------------------------------------------------------------
# IMPORTANT: must be a DIRECT (non-SRV) connection string. A mongodb+srv://
# URI is rejected at startup by app/config.py — list the hosts directly.
#
#   Single host:
#     MONGODB_URI=mongodb://localhost:27017/?directConnection=true
#   Atlas replica set (direct, non-SRV) — list all members:
#     MONGODB_URI=mongodb://user:pass@host1:27017,host2:27017/?replicaSet=rs0&tls=true&authSource=admin
MONGODB_URI=mongodb://localhost:27017/?directConnection=true
MONGODB_DB=factorypilot

# --- Multi-tenancy ----------------------------------------------------------
# Tenant used when a request carries no X-Tenant-Id header.
# Set to "" to make the header mandatory.
DEFAULT_TENANT_ID=demo

# --- API metadata -----------------------------------------------------------
API_TITLE=FactoryPilot AI
API_VERSION=0.1.0
CORS_ORIGINS=http://localhost:3000

# --- Sensor pipeline --------------------------------------------------------
# simulator | opcua | mqtt
SENSOR_SOURCE=simulator
SENSOR_INTERVAL_SECONDS=2.0
# Simulated seconds per wall-clock second. 15120 replays three weeks of
# degradation in two minutes for a demo.
SENSOR_TIME_SCALE=1.0

# --- Ingestion --------------------------------------------------------------
INGESTION_ENABLED=true
INGESTION_BATCH_SIZE=200
INGESTION_FLUSH_SECONDS=5.0
READINGS_RETENTION_DAYS=90

# --- OPC UA (only when SENSOR_SOURCE=opcua) ---------------------------------
# OPCUA_ENDPOINT=opc.tcp://localhost:4840/factorypilot
# OPCUA_NODE_MAP_PATH=config/opcua_nodes.json
# OPCUA_USERNAME=
# OPCUA_PASSWORD=
# OPCUA_SECURITY_POLICY=None
# OPCUA_PUBLISHING_INTERVAL_MS=1000
ANTHROPIC_API_KEY=sk-ant-your-key-here
# --- MQTT (only when SENSOR_SOURCE=mqtt) ------------------------------------
# MQTT_HOST=localhost
# MQTT_PORT=1883
# MQTT_TOPIC_MAP_PATH=config/mqtt_topics.json
# MQTT_USERNAME=
# MQTT_PASSWORD=
# MQTT_CLIENT_ID=factorypilot-ingest
# MQTT_QOS=1
# MQTT_TLS=false
